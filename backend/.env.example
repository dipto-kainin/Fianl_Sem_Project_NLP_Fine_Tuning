# ============================================
# AI Knowledge Distillation Platform
# Environment Configuration
# ============================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://kdp_user:kdp_password@localhost:5432/knowledge_distillation

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Google Gemini API ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# --- File Storage ---
UPLOAD_DIR=./storage/uploads
MODELS_DIR=./storage/models
DATASETS_DIR=./storage/datasets

# --- Document Processing ---
MAX_UPLOAD_SIZE_MB=100
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Student Training ---
BASE_STUDENT_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
LORA_RANK=16
LORA_ALPHA=32
TRAINING_EPOCHS=3
TRAINING_BATCH_SIZE=4
LEARNING_RATE=2e-4

# --- Teacher Fallback ---
CONFIDENCE_THRESHOLD=0.7

# --- API Settings ---
API_V1_PREFIX=/api/v1
PROJECT_NAME=AI Knowledge Distillation Platform
DEBUG=true
